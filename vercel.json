{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "cleanUrls": true,
  "functions": {
    "api/*.php": {
      "runtime": "vercel-php@0.9.0"
    }
  },
  "name": "Blue Docs",
  "regions": [ "cle1" ],
  "redirects": [
    {
      "source": "/api/:path.php",
      "destination": "/:path"
    },
    {
      "source": "/api/:path",
      "destination": "/:path"
    }
  ],
  "rewrites": [
    {
      "source": "/:match((?!public|styles).*)",
      "destination": "/api/:match.php"
    },
    {
      "source": "/",
      "destination": "/api/index.html"
    }
  ],
  "trailingSlash": false,
  "version": 2
}

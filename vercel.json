{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "cleanUrls": true,
  "functions": {
    "api/*.php": {
      "runtime": "vercel-php@0.9.0"
    }
  },
  "name": "Blue Docs",
  "regions": [ "cle1" ],
  "rewrites": [
    {
      "source": "/((?!api|public|styles).*)",
      "destination": "/api/$1.php"
    }
  ],
  "trailingSlash": false,
  "version": 2
}

{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "cleanUrls": true,
  "functions": {
    "api/*.php": {
      "runtime": "vercel-php@0.9.0"
    }
  },
  "name": "Blue Docs",
  "regions": [ "cle1" ],
  "rewrites": [
    {
      "source": "/public/(.*)",
      "destination": "/public/$1"
    },
    {
      "source": "/styles/(.*)",
      "destination": "/styles/$1"
    },
    {
      "source": "/((?!api/).*)",
      "destination": "/api/index.php"
    }
  ],
  "trailingSlash": false,
  "version": 2
}
